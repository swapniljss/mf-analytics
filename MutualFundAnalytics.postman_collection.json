              "path": ["portfolio", "overlap"],
              "query": [
                { "key": "amfi_code_1", "value": "120503", "description": "First scheme AMFI code" },
                { "key": "amfi_code_2", "value": "120504", "description": "Second scheme AMFI code" },
                { "key": "report_month", "value": "{{report_month}}" }
              ]
            },
            "description": "Computes ISIN-weighted portfolio overlap between two schemes. overlap_percentage = sum of min(w1, w2) for common stocks."
          }
        },
        {
          "name": "Portfolio Concentration",
          "request": {
            "method": "GET",
