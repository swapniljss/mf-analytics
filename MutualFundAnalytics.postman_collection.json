                { "key": "search", "value": "HDFC" },
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "100" }
              ]
            }
          }
        },
        {
          "name": "Top Holdings for Scheme",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/portfolio/top-holdings/{{amfi_code}}?report_month={{report_month}}&limit=10",
