              ]
            }
          }
        }
      ]
    },
    {
      "name": "6. Disclosures",
      "item": [
        {
          "name": "Monthly Disclosure",
          "item": [
            {
              "name": "Upload Monthly Disclosure",
              "request": {
                "method": "POST",
                "url": { "raw": "{{base_url}}/disclosure/monthly/upload", "host": ["{{base_url}}"], "path": ["disclosure", "monthly", "upload"] },
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "file", "type": "file", "src": "/path/to/amfeb2026repo.xls" },
                    { "key": "report_month", "value": "2026-02" }
                  ]
                }
              }
            },
            {
              "name": "List Monthly Uploads",
              "request": {
                "method": "GET",
                "url": { "raw": "{{base_url}}/disclosure/monthly/uploads", "host": ["{{base_url}}"], "path": ["disclosure", "monthly", "uploads"] }
              }
            },
            {
              "name": "Browse Monthly Rows",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/disclosure/monthly/rows?amfi_code={{amfi_code}}&page=1&page_size=50",
                  "host": ["{{base_url}}"],
                  "path": ["disclosure", "monthly", "rows"],
                  "query": [{ "key": "amfi_code", "value": "{{amfi_code}}" }, { "key": "page", "value": "1" }, { "key": "page_size", "value": "50" }]
                }
              }
            }
          ]
        },
        {
          "name": "Quarterly Disclosure",
          "item": [
            {
              "name": "Upload Quarterly Disclosure",
              "request": {
                "method": "POST",
                "url": { "raw": "{{base_url}}/disclosure/quarterly/upload", "host": ["{{base_url}}"], "path": ["disclosure", "quarterly", "upload"] },
                "body": {
                  "mode": "formdata",
                  "formdata": [
